# ========================================================================
# SMOKE TEST ENVIRONMENT VARIABLES
# ========================================================================
# Configuration for the n8n smoke test environment.
# This file is loaded by compose.smoke.yml and scripts/smoke-test.sh
#
# IMPORTANT: N8N_ENCRYPTION_KEY will be auto-generated by smoke-test.sh
# if it doesn't exist. Do not commit this file with real keys!
# ========================================================================

# ----------------------------------------------------------------------
# n8n Core Configuration
# ----------------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/

# ----------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------
# Auto-generated 32-byte hex key for encrypting credentials in DB
# Will be created by smoke-test.sh if missing
# N8N_ENCRYPTION_KEY=<will-be-generated>

# ----------------------------------------------------------------------
# PostgreSQL Configuration
# ----------------------------------------------------------------------
DB_POSTGRESDB=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=n8n
DB_POSTGRESDB_HOST=db
DB_POSTGRESDB_PORT=5432

# ----------------------------------------------------------------------
# Binary Data Storage
# ----------------------------------------------------------------------
# Use filesystem storage to avoid bloating the database with video files
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# ========================================================================
# WORKFLOW CREDENTIALS (Configure in n8n UI)
# ========================================================================
# The following credentials must be configured manually in the n8n UI
# at http://localhost:5678 before running the smoke test execution:
#
# 1. YouTube OAuth2 API
#    - Redirect URL: http://localhost:5678/rest/oauth2-credential/callback
#    - Scopes: Required YouTube API scopes for video access
#
# 2. LLM API (e.g., OpenAI, Anthropic, etc.)
#    - Provider-specific API key
#    - Model configuration as needed by workflow
#
# 3. Video Renderer API (Swiftia or similar)
#    - API key/token for the rendering service
#    - Endpoint configuration
#
# These are NOT environment variables - they are stored encrypted in
# the n8n database and attached to workflow nodes via the UI.
# ========================================================================
