# ========================================================================
# PRODUCTION ENVIRONMENT — copiar para .env.prod e preencher
# ========================================================================
# NUNCA fazer commit deste ficheiro com valores reais

# --- n8n ---
# O teu domínio público (configurado no Cloudflare Tunnel)
N8N_HOST=n8n.seudominio.com

# Chave de encriptação para credenciais — gerar com:
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# --- Base de dados ---
DB_POSTGRESDB=n8n
DB_POSTGRESDB_USER=n8n
# Password forte — gerar com: openssl rand -hex 24
DB_POSTGRESDB_PASSWORD=

# --- Serviço video-shorts ---
GEMINI_API_KEY=
# base = mais rápido/leve | small = mais preciso (precisa de mais RAM)
WHISPER_MODEL=base

# --- Cloudflare Tunnel ---
# Token gerado em: https://one.dash.cloudflare.com → Access → Tunnels → Create tunnel
# Configurar o tunnel para apontar http://n8n:5678
CLOUDFLARE_TUNNEL_TOKEN=
