    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ---- Extract YouTube Video ID from URL or plain ID ----\nconst rawLink = item.json['Link do vídeo do YouTube'] || '';\nlet videoId = rawLink.trim();\n\n// Try to extract ID from various YouTube URL formats\nconst patterns = [\n  /[?&]v=([a-zA-Z0-9_-]{11})/,           // youtube.com/watch?v=ID\n  /youtu\\.be\\/([a-zA-Z0-9_-]{11})/,        // youtu.be/ID\n  /\\/embed\\/([a-zA-Z0-9_-]{11})/,          // youtube.com/embed/ID\n  /\\/shorts\\/([a-zA-Z0-9_-]{11})/,         // youtube.com/shorts/ID\n  /\\/live\\/([a-zA-Z0-9_-]{11})/,           // youtube.com/live/ID\n];\nfor (const pat of patterns) {\n  const m = rawLink.match(pat);\n  if (m) { videoId = m[1]; break; }\n}\n// If it's already an 11-char ID, keep it\nif (/^[a-zA-Z0-9_-]{11}$/.test(videoId)) {\n  // OK\n} else if (videoId.length > 11) {\n  // Last resort: try to find 11-char segment\n  const fallback = videoId.match(/([a-zA-Z0-9_-]{11})/);\n  if (fallback) videoId = fallback[1];\n}\n\n// ---- Combine date + time into ISO 8601 ----\nconst rawDate = item.json['Data da primeira publicação'] || new Date().toISOString().slice(0, 10);\nconst rawTime = item.json['Horário de publicação (HH:MM, UTC)'] || '08:00';\nconst timeParts = rawTime.trim().match(/(\\d{1,2}):(\\d{2})/);\nconst hh = timeParts ? timeParts[1].padStart(2, '0') : '08';\nconst mm = timeParts ? timeParts[2] : '00';\nconst firstPublicationAt = `${rawDate}T${hh}:${mm}:00Z`;\n\n// ---- Map duration dropdown to min/max ----\nconst durSelection = item.json['Duração média dos Shorts'] || '🎯 30-45s';\nconst durMap = {\n  '15-30': { min: 15, max: 30 },\n  '30-45': { min: 30, max: 45 },\n  '45-59': { min: 45, max: 59 },\n  '60-90': { min: 60, max: 90 },\n};\nlet targetDurMin = 30, targetDurMax = 45; // default\nfor (const [key, val] of Object.entries(durMap)) {\n  if (durSelection.includes(key)) { targetDurMin = val.min; targetDurMax = val.max; break; }\n}\n\n// ---- Map caption style dropdown to preset key ----\nconst styleSelection = item.json['Estilo das legendas'] || 'CapCut Bold';\nconst styleMap = {\n  'CapCut Bold': 'capcut-bold',\n  'Clean Minimal': 'clean-minimal',\n  'Neon Glow': 'neon-glow',\n  'MrBeast': 'mrbeast',\n  'Podcast': 'podcast',\n  'Karaoke': 'karaoke',\n};\nlet captionPreset = 'capcut-bold';\nfor (const [key, val] of Object.entries(styleMap)) {\n  if (styleSelection.includes(key)) { captionPreset = val; break; }\n}\n\n// ---- Map niche dropdown to clean string ----\nconst nicheRaw = item.json['Nicho do canal'] || 'tecnologia e internet';\n// Strip emoji prefix if present\nconst channelNiche = nicheRaw.replace(/^[^a-zA-ZÀ-ú]+/, '').trim() || 'tecnologia e internet';\n\nconst targetAudience = item.json['Público-alvo (opcional)'] || '';\n\nreturn {\n  json: {\n    videoSource: 'youtube',\n    videoId,\n    firstPublicationAt,\n    intervalHours: Number(item.json['Intervalo entre publicações (horas)']) || 6,\n    captionPreset,\n    targetDurMin,\n    targetDurMax,\n    channelNiche,\n    targetAudience,\n  }\n};"
      },
