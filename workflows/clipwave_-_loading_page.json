        "responseBody": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>ClipWave - Processando</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nbody{min-height:100vh;display:flex;align-items:center;justify-content:center;background:#0a0a0f;font-family:'Inter',sans-serif;color:#fff;overflow:hidden}\n.bg{position:fixed;inset:0;z-index:0}\n.orb{position:absolute;border-radius:50%;filter:blur(80px);opacity:.35;animation:float 8s ease-in-out infinite}\n.orb1{width:400px;height:400px;background:#7c3aed;top:-100px;left:-100px;animation-delay:0s}\n.orb2{width:350px;height:350px;background:#2563eb;bottom:-80px;right:-80px;animation-delay:2s}\n.orb3{width:300px;height:300px;background:#ec4899;top:50%;left:50%;transform:translate(-50%,-50%);animation-delay:4s}\n@keyframes float{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(30px,-30px) scale(1.1)}}\n.card{position:relative;z-index:1;background:rgba(255,255,255,.05);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.1);border-radius:24px;padding:48px 40px;max-width:520px;width:90%;box-shadow:0 25px 50px rgba(0,0,0,.4)}\n.logo{text-align:center;margin-bottom:32px}\n.logo h1{font-size:28px;font-weight:700;background:linear-gradient(135deg,#7c3aed,#2563eb,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}\n.logo p{color:rgba(255,255,255,.5);font-size:14px;margin-top:4px}\n.steps{display:flex;flex-direction:column;gap:16px}\n.step{display:flex;align-items:center;gap:16px;padding:14px 18px;border-radius:14px;transition:all .5s ease;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.05)}\n.step.active{background:rgba(124,58,237,.12);border-color:rgba(124,58,237,.3)}\n.step.done{background:rgba(34,197,94,.08);border-color:rgba(34,197,94,.2)}\n.step.error{background:rgba(239,68,68,.08);border-color:rgba(239,68,68,.3)}\n.step-icon{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;background:rgba(255,255,255,.08);transition:all .5s ease}\n.step.active .step-icon{background:rgba(124,58,237,.25);box-shadow:0 0 20px rgba(124,58,237,.3)}\n.step.done .step-icon{background:rgba(34,197,94,.2)}\n.step.error .step-icon{background:rgba(239,68,68,.2)}\n.step-text{flex:1}\n.step-text h3{font-size:14px;font-weight:600;color:rgba(255,255,255,.9);transition:color .5s}\n.step-text p{font-size:12px;color:rgba(255,255,255,.4);margin-top:2px;transition:color .5s}\n.step.active .step-text h3{color:#fff}\n.step.active .step-text p{color:rgba(255,255,255,.6)}\n.step.done .step-text h3{color:rgba(34,197,94,.9)}\n.step.error .step-text h3{color:rgba(239,68,68,.9)}\n.step.error .step-text p{color:rgba(239,68,68,.6)}\n.step-status{width:24px;height:24px;border-radius:50%;border:2px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;transition:all .5s ease;flex-shrink:0}\n.step.active .step-status{border-color:#7c3aed;animation:pulse 2s ease-in-out infinite}\n.step.done .step-status{border-color:#22c55e;background:#22c55e}\n.step.done .step-status::after{content:'\\2713';font-size:12px;color:#fff;font-weight:700}\n.step.error .step-status{border-color:#ef4444;background:#ef4444}\n.step.error .step-status::after{content:'\\2717';font-size:12px;color:#fff;font-weight:700}\n@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(124,58,237,.4)}50%{box-shadow:0 0 0 8px rgba(124,58,237,0)}}\n.spinner{width:14px;height:14px;border:2px solid transparent;border-top-color:#7c3aed;border-radius:50%;animation:spin 1s linear infinite;display:none}\n.step.active .spinner{display:block}\n@keyframes spin{to{transform:rotate(360deg)}}\n.progress-bar{margin-top:28px;height:4px;background:rgba(255,255,255,.08);border-radius:4px;overflow:hidden}\n.progress-fill{height:100%;background:linear-gradient(90deg,#7c3aed,#2563eb,#ec4899);border-radius:4px;transition:width 1s ease;width:14%}\n.footer{text-align:center;margin-top:24px;font-size:12px;color:rgba(255,255,255,.3)}\n.error-msg{text-align:center;margin-top:16px;padding:12px 16px;border-radius:10px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);color:rgba(239,68,68,.9);font-size:13px;display:none}\n</style>\n</head>\n<body>\n<div class=\"bg\"><div class=\"orb orb1\"></div><div class=\"orb orb2\"></div><div class=\"orb orb3\"></div></div>\n<div class=\"card\">\n<div class=\"logo\"><h1>ClipWave</h1><p>Transformando seu v&iacute;deo em Shorts</p></div>\n<div class=\"steps\">\n<div class=\"step done\" data-step=\"0\"><div class=\"step-icon\">&#x1F4CB;</div><div class=\"step-text\"><h3>Formul&aacute;rio recebido</h3><p>Dados validados com sucesso</p></div><div class=\"step-status\"><div class=\"spinner\"></div></div></div>\n<div class=\"step active\" data-step=\"1\"><div class=\"step-icon\">&#x1F4CA;</div><div class=\"step-text\"><h3>Analisando tend&ecirc;ncias</h3><p>Pesquisando trending topics</p></div><div class=\"step-status\"><div class=\"spinner\"></div></div></div>\n<div class=\"step\" data-step=\"2\"><div class=\"step-icon\">&#x1F916;</div><div class=\"step-text\"><h3>IA selecionando momentos</h3><p>Identificando melhores trechos</p></div><div class=\"step-status\"><div class=\"spinner\"></div></div></div>\n<div class=\"step\" data-step=\"3\"><div class=\"step-icon\">&#x2B07;&#xFE0F;</div><div class=\"step-text\"><h3>Baixando e transcrevendo</h3><p>Processando &aacute;udio e v&iacute;deo</p></div><div class=\"step-status\"><div class=\"spinner\"></div></div></div>\n<div class=\"step\" data-step=\"4\"><div class=\"step-icon\">&#x2702;&#xFE0F;</div><div class=\"step-text\"><h3>Cortando segmentos</h3><p>Extraindo os melhores clips</p></div><div class=\"step-status\"><div class=\"spinner\"></div></div></div>\n<div class=\"step\" data-step=\"5\"><div class=\"step-icon\">&#x1F3AC;</div><div class=\"step-text\"><h3>Renderizando Shorts</h3><p>Adicionando legendas e efeitos</p></div><div class=\"step-status\"><div class=\"spinner\"></div></div></div>\n<div class=\"step\" data-step=\"6\"><div class=\"step-icon\">&#x1F4E4;</div><div class=\"step-text\"><h3>Enviando para aprova&ccedil;&atilde;o</h3><p>Preparando planilha de revis&atilde;o</p></div><div class=\"step-status\"><div class=\"spinner\"></div></div></div>\n</div>\n<div class=\"progress-bar\"><div class=\"progress-fill\"></div></div>\n<div class=\"error-msg\" id=\"errorMsg\"></div>\n<div class=\"footer\" id=\"footer\">Tempo estimado: 3-8 minutos</div>\n</div>\n<script>\n(function(){\n  const steps=document.querySelectorAll('.step');\n  const fill=document.querySelector('.progress-fill');\n  const footer=document.getElementById('footer');\n  const errorMsg=document.getElementById('errorMsg');\n  // Proxy endpoint: n8n webhook that forwards to video-shorts:8000\n  const API='https://clipwave.app/webhook/pipeline-status';\n  let lastIdx=-1;\n  let pollCount=0;\n  let isDone=false;\n  let errCount=0;\n\n  function setStep(idx,isError){\n    steps.forEach(function(s,i){\n      s.classList.remove('active','done','error');\n      if(isError&&i===idx){s.classList.add('error')}\n      else if(i<idx){s.classList.add('done')}\n      else if(i===idx){s.classList.add(isError?'error':'active')}\n    });\n    var pct=isError?((idx)/7*100):Math.min(((idx+1)/7*100),100);\n    fill.style.width=pct+'%';\n    if(isError){fill.style.background='linear-gradient(90deg,#ef4444,#dc2626)';}\n  }\n\n  function showDone(){\n    steps.forEach(function(s){s.classList.remove('active');s.classList.add('done')});\n    fill.style.width='100%';\n    fill.style.background='linear-gradient(90deg,#22c55e,#16a34a)';\n    footer.textContent='Processamento conclu\\u00eddo! Verifique sua planilha de aprova\\u00e7\\u00e3o.';\n    isDone=true;\n  }\n\n  function showError(msg){\n    errorMsg.textContent=msg||'Ocorreu um erro no processamento.';\n    errorMsg.style.display='block';\n    footer.textContent='Erro no processamento. Verifique os logs ou tente novamente.';\n    isDone=true;\n  }\n\n  function poll(){\n    if(isDone)return;\n    pollCount++;\n\n    fetch(API).then(function(r){\n      if(!r.ok){\n        errCount++;\n        // n8n may return 500 if video-shorts is down; keep trying\n        if(errCount>20){\n          showError('Servi\\u00e7o indispon\\u00edvel. Tente novamente mais tarde.');\n        }\n        return null;\n      }\n      errCount=0;\n      return r.json();\n    }).then(function(d){\n      if(!d)return;\n\n      var idx=d.stepIndex||0;\n\n      if(d.error){\n        setStep(idx,true);\n        showError(d.detail||'Erro no processamento');\n        return;\n      }\n      if(d.step==='done'){\n        showDone();\n        return;\n      }\n      // \"waiting\" means no job exists yet — n8n is still processing form\n      if(d.step==='waiting'){\n        // Keep step 1 active (trend analysis in n8n)\n        if(lastIdx<1){setStep(1,false);lastIdx=1;}\n        return;\n      }\n\n      // Ensure we only move forward, never backward\n      if(idx>lastIdx){\n        setStep(idx,false);\n        lastIdx=idx;\n      }\n\n      // Update detail text on active step\n      if(d.detail){\n        var active=document.querySelector('.step.active .step-text p');\n        if(active)active.textContent=d.detail;\n      }\n\n      // Update footer with elapsed time\n      if(pollCount>10){\n        var mins=Math.floor(pollCount*3/60);\n        var secs=(pollCount*3)%60;\n        footer.textContent='Processando h\\u00e1 '+mins+'m'+String(secs).padStart(2,'0')+'s...';\n      }\n    }).catch(function(){\n      errCount++;\n      if(errCount>30){\n        showError('Conex\\u00e3o perdida. Verifique a planilha de aprova\\u00e7\\u00e3o.');\n      }\n    });\n  }\n\n  // Initial state: step 0 done, step 1 active\n  setStep(1,false);\n  lastIdx=1;\n\n  // Poll every 3 seconds, first poll after 5s\n  setTimeout(poll,5000);\n  setInterval(poll,3000);\n\n  // Safety: stop after 15 minutes\n  setTimeout(function(){\n    if(!isDone){\n      footer.textContent='Tempo limite atingido. Verifique a planilha de aprova\\u00e7\\u00e3o.';\n      isDone=true;\n    }\n  },900000);\n})();\n</script>\n</body>\n</html>",
